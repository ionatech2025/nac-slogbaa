#!/usr/bin/env bash
# =============================================================================
# SLOGBAA Pre-Commit Hook — Secret Leak Prevention (2026 DevSecOps)
#
# Scans staged files for:
#   1. High-entropy strings (API keys, tokens, passwords)
#   2. Known secret patterns (AWS, Neon, JWT, SMTP credentials)
#   3. Forbidden file types (.env, .pem, .key, credentials.json)
#
# Install: git config core.hooksPath .githooks
# Bypass (emergencies ONLY): git commit --no-verify
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

BLOCKED=0

echo "--- Secret scan: checking staged files ---"

# ─────────────────────────────────────────────────────────────────────────────
# 1. Block forbidden files from being committed
# ─────────────────────────────────────────────────────────────────────────────
FORBIDDEN_PATTERNS=(
  '\.env$'
  '\.env\.local$'
  '\.env\.production$'
  '\.env\.staging$'
  '\.pem$'
  '\.key$'
  '\.p12$'
  '\.jks$'
  'credentials\.json$'
  'service-account.*\.json$'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}No staged files to scan.${NC}"
  exit 0
fi

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | grep -E "$pattern" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}BLOCKED: Forbidden file staged for commit:${NC}"
    echo "$MATCHES" | while read -r f; do echo "  $f"; done
    BLOCKED=1
  fi
done

# ─────────────────────────────────────────────────────────────────────────────
# 2. Scan staged content for secret patterns
# ─────────────────────────────────────────────────────────────────────────────
SECRET_PATTERNS=(
  # Neon PostgreSQL
  'npg_[A-Za-z0-9]{10,}'
  # Generic connection strings with passwords
  'postgresql://[^:]+:[^@]+@'
  # AWS keys
  'AKIA[0-9A-Z]{16}'
  'aws_secret_access_key\s*=\s*[A-Za-z0-9/+=]{20,}'
  # JWT / Bearer tokens (long base64)
  'eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.'
  # Generic API keys
  'sk-[A-Za-z0-9]{20,}'
  'sk_live_[A-Za-z0-9]{20,}'
  # SMTP password with value
  'SMTP_PASSWORD=[^\s<]{4,}'
  # Private keys
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
  # GitHub tokens
  'gh[pousr]_[A-Za-z0-9]{20,}'
  # Generic password assignments with real values (not placeholders)
  'PASSWORD=[^\s<$]{8,}'
)

# Only scan text files, skip binaries, .env.example, and this hook file itself
SCANNABLE=$(echo "$STAGED_FILES" | grep -vE '\.(png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot|pdf|zip|jar|class)$' | grep -v '\.env\.example$' | grep -v '\.githooks/pre-commit$' || true)

if [ -n "$SCANNABLE" ]; then
  for pattern in "${SECRET_PATTERNS[@]}"; do
    # Search staged content (not working tree) via git show
    HITS=$(echo "$SCANNABLE" | while read -r file; do
      git show ":$file" 2>/dev/null | grep -nE "$pattern" 2>/dev/null | while read -r line; do
        echo "  $file:$line"
      done
    done || true)

    if [ -n "$HITS" ]; then
      echo -e "${RED}BLOCKED: Potential secret detected (pattern: ${pattern:0:30}...):${NC}"
      echo "$HITS" | head -5
      BLOCKED=1
    fi
  done
fi

# ─────────────────────────────────────────────────────────────────────────────
# 3. Result
# ─────────────────────────────────────────────────────────────────────────────
if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo -e "${RED}COMMIT BLOCKED: Potential secrets detected in staged files.${NC}"
  echo -e "${YELLOW}Fix: Remove secrets from staged files, use .env files instead.${NC}"
  echo -e "${YELLOW}Emergency bypass: git commit --no-verify (NOT recommended)${NC}"
  exit 1
fi

echo -e "${GREEN}No secrets detected. Commit allowed.${NC}"
exit 0
