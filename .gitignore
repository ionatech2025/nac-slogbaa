# =============================================================================
# SLOGBAA - Root gitignore
# =============================================================================

# ---- Secrets ----
.env
.env.local
.env.*.local

# ---- Backend (Gradle/Java) ----
backend/build/
backend/**/build/
!**/src/main/**/build/
!**/src/test/**/build/
backend/.gradle/

# ---- Frontend (Node) ----
frontend/node_modules/
frontend/dist/
frontend/*.local

# ---- IDE ----
.idea/
*.iws
*.iml
*.ipr
.vscode/
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Misc ----
HELP.md
