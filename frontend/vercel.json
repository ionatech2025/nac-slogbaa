{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://rachel-spelling-generation-differential.trycloudflare.com"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}