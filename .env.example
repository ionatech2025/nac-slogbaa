# =============================================================================
# SLOGBAA Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
# =============================================================================

# ---- Database ----
POSTGRES_DB=slogbaa
POSTGRES_USER=slogbaa
POSTGRES_PASSWORD=<set-a-strong-password>

# ---- Backend ----
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=<set-a-strong-secret-at-least-32-characters>
CORS_ALLOWED_ORIGINS=https://your-domain.com
PASSWORD_RESET_BASE_URL=https://your-domain.com

# ---- Mail (optional) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<set-in-env>
SMTP_PASSWORD=<set-in-env>
