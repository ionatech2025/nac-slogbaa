# =============================================================================
# SLOGBAA — Environment Variables Template
# Copy to .env and fill in values:  cp .env.example .env
#
# NEVER commit .env or .env.local — they contain secrets.
# Only .env.example is committed (with placeholder values).
# =============================================================================

# ---- Database (Neon Serverless PostgreSQL) ----
POSTGRES_DB=slogbaa
POSTGRES_USER=<set-in-env>
POSTGRES_PASSWORD=<set-in-env>

# Spring Boot datasource (JDBC)
DATASOURCE_URL=jdbc:postgresql://<neon-host>.ap-southeast-1.aws.neon.tech/slogbaa?sslmode=require
DATASOURCE_USERNAME=<set-in-env>
DATASOURCE_PASSWORD=<set-in-env>

# ---- Backend (Spring Boot) ----
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=<set-a-strong-secret-at-least-32-characters>
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Email links (verify / reset). Local: http://localhost:5173. Railway: SPRING_PROFILES_ACTIVE=prod + https://nac-slogbaa.vercel.app
# If you paste a comma-separated list (like CORS), dev profile uses localhost; prod uses first https:// URL.
PASSWORD_RESET_BASE_URL=http://localhost:5173

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8080

# ---- Mail (REQUIRED for verification emails to reach inbox) ----
# Dev: SMTP — GMAIL_USER/GMAIL_APP_PASS or SMTP_USERNAME/SMTP_PASSWORD (default EMAIL_PROVIDER=smtp).
# Dev or prod: Resend — EMAIL_PROVIDER=resend + RESEND_API_KEY + RESEND_FROM (same as Railway).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<set-in-env>
SMTP_PASSWORD=<set-in-env>

# Resend (optional — omit or set smtp to use Gmail/SMTP above)
EMAIL_PROVIDER=smtp
# Resend HTTP API: https://resend.com/api-keys — variable name is RESEND_API_KEY (not RESENT_*).
# If you see HTTP 403: verify a domain at resend.com/domains and set RESEND_FROM to that domain;
# with onboarding@resend.dev you can usually only send to your own Resend-account email in dev.
RESEND_API_KEY=<set-in-env>
RESEND_FROM=SLOGBAA <onboarding@resend.dev>

# ---- File Storage ----
FILE_UPLOAD_DIR=uploads

# ---- Sentry (Frontend error tracking) ----
VITE_SENTRY_DSN=<set-in-env>
