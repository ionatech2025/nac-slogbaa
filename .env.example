# =============================================================================
# SLOGBAA — Environment Variables Template
# Copy to .env and fill in values:  cp .env.example .env
#
# NEVER commit .env or .env.local — they contain secrets.
# Only .env.example is committed (with placeholder values).
# =============================================================================

# ---- Database (Neon Serverless PostgreSQL) ----
POSTGRES_DB=slogbaa
POSTGRES_USER=<set-in-env>
POSTGRES_PASSWORD=<set-in-env>

# Spring Boot datasource (JDBC)
DATASOURCE_URL=jdbc:postgresql://<neon-host>.ap-southeast-1.aws.neon.tech/slogbaa?sslmode=require
DATASOURCE_USERNAME=<set-in-env>
DATASOURCE_PASSWORD=<set-in-env>

# ---- Backend (Spring Boot) ----
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=<set-a-strong-secret-at-least-32-characters>
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
PASSWORD_RESET_BASE_URL=http://localhost:5173

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8080

# ---- Mail (optional — leave blank to use logging adapter) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<set-in-env>
SMTP_PASSWORD=<set-in-env>

# ---- File Storage ----
FILE_UPLOAD_DIR=uploads
